---
import '../styles/globals.css';

export interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Formulario de Libro de Reclamaciones - Registra tu reclamo o queja de manera sencilla y segura." />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="theme-color" content="#E41517" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<style>
			@import url('https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&family=DM+Mono:ital,wght@0,400;0,500;1,400;1,500&display=swap');
			html {
				--font-dm-sans: 'DM Sans', system-ui, sans-serif;
				--font-dm-mono: 'DM Mono', ui-monospace, SFMono-Regular, 'SF Mono', monospace;
			}
			body {
				font-family: var(--font-dm-sans);
			}
		</style>
	</head>
	<body class="font-sans antialiased">
		<slot />
	</body>
</html>